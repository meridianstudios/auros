{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://oauth2.googleapis.com/*" }]
    },
    "notification:default"
  ]
}
